<!-- ================= hero section ================= -->
<div class="position-relative">
    <div id="heroCarousel" class="carousel slide" data-bs-ride="carousel">
        <div class="carousel-inner">

            <div class="carousel-item active">
                <img src="~/images/slide1.jpg" class="d-block w-100 hero-img" />
            </div>

            <div class="carousel-item">
                <img src="~/images/slide2.jpg" class="d-block w-100 hero-img" />
            </div>

        </div>
    </div>

    <!-- Overlay -->
    <div class="hero-overlay text-center text-white">
        <h1 class="display-4 fw-bold">Find Your Perfect Stay</h1>
        <p class="lead">Luxury villas, unforgettable experiences</p>
    </div>
</div>

<!-- ================= search section ================= -->
<div class="container position-relative" style="margin-top:-60px;">
    <div class="card shadow-lg p-4 rounded-4">
        <form method="post">
            <div class="row g-3 align-items-end">

                <div class="col-md-5">
                    <label class="form-label">Check-in Date</label>
                    <input asp-for="CheckInDate" type="date" class="form-control" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Nights</label>
                    <select class="form-select">
                        @for (int i = 1; i <= 10; i++)
                        {
                            <option value="@i">@i</option>
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <button type="button" class="btn btn-success w-100">
                        Check Availability
                    </button>
                </div>

            </div>
        </form>
    </div>
</div>

<!-- ================= villa list section ================= -->
<section class="container my-5">

    <h2 class="text-center mb-4">Featured Villas</h2>

    <div class="row g-4">

        @foreach (var villa in Model.VillaList)
        {
            <div class="col-12 col-md-6 col-lg-4">

                <div class="card h-100 shadow-sm border-0 rounded-4">

                    <img src="@villa.ImageUrl"
                         class="card-img-top"
                         style="height:220px; object-fit:cover;" />

                    <div class="card-body d-flex flex-column">

                        <h5 class="fw-bold text-warning">@villa.Name</h5>

                        <p class="small flex-grow-1">
                            @Html.Raw(villa.Description)
                        </p>

                        <div class="mb-2 small text-muted">
                            Max: @villa.Occupancy adults <br />
                            Size: @villa.Sqft sqft
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-auto">
                            <span class="fw-bold text-success">
                                @villa.Price.ToString("c") / night
                            </span>

                            <div>
                                <button class="btn btn-sm btn-outline-success"
                                        data-bs-toggle="modal"
                                        data-bs-target="#villaModal-@villa.Id">
                                    Details
                                </button>

                                <button class="btn btn-sm btn-success">
                                    Book
                                </button>
                            </div>
                        </div>

                    </div>
                </div>

            </div>

            <!-- ================= modal ================= -->
            <partial name="_VillaDetail" model="@villa"/>

        }

    </div>

</section>

<!-- ================= AMENITIES SECTION ================= -->
<section class="container my-5">

    <h2 class="text-center mb-4">Resort Amenities</h2>

    <div class="row g-4 text-center">

        <div class="col-6 col-md-3">
            <div class="p-4 shadow-sm rounded-4">
                <i class="bi bi-water fs-1 text-primary"></i>
                <p class="mt-2">Swimming Pool</p>
            </div>
        </div>

        <div class="col-6 col-md-3">
            <div class="p-4 shadow-sm rounded-4">
                <i class="bi bi-wifi fs-1 text-success"></i>
                <p class="mt-2">Free WiFi</p>
            </div>
        </div>

        <div class="col-6 col-md-3">
            <div class="p-4 shadow-sm rounded-4">
                <i class="bi bi-cup-hot fs-1 text-warning"></i>
                <p class="mt-2">Restaurant</p>
            </div>
        </div>

        <div class="col-6 col-md-3">
            <div class="p-4 shadow-sm rounded-4">
                <i class="bi bi-car-front fs-1 text-danger"></i>
                <p class="mt-2">Parking</p>
            </div>
        </div>

    </div>

</section>

