<div class="container mt-5">
    <div class="resort-container shadow-lg">

        <div class="resort-header-gray p-4 d-flex align-items-center">
            <div class="d-flex justify-content-between align-items-center w-100">
                <div>
                    <h2 class="text-white m-0 fw-bold" style="letter-spacing: -0.5px;">Amenity List</h2>
                </div>

                <div class="mt-3">
                    <a asp-controller="Amenity" asp-action="Create" class="btn btn-gray-steel">
                        <i class="bi bi-plus-square-fill me-2"></i> NEW AMENITY
                    </a>
                </div>
            </div>
        </div>

        @* Table Area *@
        <div class="table-responsive">
            <table class="table table-resort table-hover">
                <thead>
                    <tr>
                        <th class="text-center" style="width: 10%;">#</th>
                        <th style="width: 40%;">Amenity Name</th>
                        <th style="width: 30%;">Villa Association</th>
                        <th class="text-end pe-4" style="width: 20%;">Manage</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var obj in Model)
                    {
                        <tr>
                            <td class="text-center text-muted">@obj.Id</td>
                            <td class="fw-bold">@obj.Name</td>
                            <td>
                                <span style="color: #64748b; font-style: italic;">@obj.Villa.Name</span>
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group">
                                    <a asp-controller="Amenity" asp-action="Update" asp-route-amenityId="@obj.Id"
                                       class="btn btn-sm btn-outline-secondary border-0 text-white-50">
                                        <i class="bi bi-pencil-fill"></i>
                                    </a>
                                    <a asp-controller="Amenity" asp-action="Delete" asp-route-amenityId="@obj.Id"
                                       class="btn btn-sm btn-outline-danger border-0">
                                        <i class="bi bi-x-circle-fill"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>