@model AmenityVM

<div class="container mt-5 d-flex justify-content-center">
    <div class="resort-container form-container shadow-lg w-100">

        <!-- Header -->
        <div class="resort-header-gray p-4 d-flex justify-content-between align-items-center">
            <h2 class="text-white m-0 fw-bold">Update Amenity</h2>

            <a asp-action="Index" class="btn btn-outline-light btn-sm">
                Back
            </a>
        </div>

        <!-- Body -->
        <div class="p-4" style="background-color: #2a364a;">

            <form method="post" class="row g-3">
                <input asp-for="Amenity.Id" hidden />

                <!-- Villa -->
                <div class="col-12">
                    <label class="text-white-50">Villa</label>
                    <select asp-for="Amenity.VillaId"
                            asp-items="Model.VillaList"
                            class="form-select text-white border-0"
                            style="background-color: #1f2937;">
                        <option disabled>-- Select Villa --</option>
                    </select>
                    <span asp-validation-for="Amenity.VillaId" class="text-danger"></span>
                </div>

                <!-- Name -->
                <div class="col-12">
                    <label class="text-white-50">Name</label>
                    <input asp-for="Amenity.Name"
                           class="form-control text-white border-0"
                           style="background-color: #1f2937;" />
                    <span asp-validation-for="Amenity.Name" class="text-danger"></span>
                </div>

                <!-- Description -->
                <div class="col-12">
                    <label class="text-white-50">Description</label>
                    <textarea asp-for="Amenity.Description"
                              rows="3"
                              class="form-control text-white border-0"
                              style="background-color: #1f2937;"></textarea>
                    <span asp-validation-for="Amenity.Description" class="text-danger"></span>
                </div>

                <!-- Buttons -->
                <div class="d-flex justify-content-end gap-2 pt-3">

                    <a asp-controller="Amenity" asp-action="Index"
                       class="btn btn-outline-secondary">
                        Cancel
                    </a>

                    <button type="submit" class="btn btn-gray-steel">
                        <i class="bi bi-check-circle-fill me-2"></i> Update
                    </button>

                </div>

            </form>
        </div>
    </div>
</div>


@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }
}

