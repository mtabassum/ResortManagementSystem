@model ResortManagement.Web.ViewModels.AmenityVM

<div class="container mt-5 d-flex justify-content-center">
    <div class="resort-container form-container shadow-lg w-100">

        <div class="resort-header-gray p-4 d-flex justify-content-between align-items-center">
            <h2 class="text-white m-0 fw-bold">Create Amenity</h2>

            <a asp-action="Index" class="btn btn-outline-light btn-sm">
                Back
            </a>
        </div>

        <div class="p-4" style="background-color: #2a364a;">

            <form method="post" class="row g-3">

                <div class="col-12">
                    <label class="text-white-50">Villa</label>
                    <select asp-for="Amenity.VillaId" asp-items="Model.VillaList"
                            class="form-select border-0 text-white"
                            style="background-color: #1f2937;">
                        <option disabled selected>-- Select Villa --</option>
                    </select>
                </div>

                <div class="col-12">
                    <label class="text-white-50">Name</label>
                    <input asp-for="Amenity.Name"
                           class="form-control text-white border-0"
                           style="background-color: #1f2937;" />
                </div>

                <div class="col-12">
                    <label class="text-white-50">Description</label>
                    <textarea asp-for="Amenity.Description"
                              rows="3"
                              class="form-control text-white border-0"
                              style="background-color: #1f2937;"></textarea>
                </div>

                <div class="d-flex justify-content-end gap-2 pt-3">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Cancel
                    </a>

                    <button type="submit" class="btn btn-gray-steel">
                        Create
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}