<div class="container mt-5 d-flex justify-content-center">
    <div class="resort-container form-container shadow-lg w-100">

        <!-- Header -->
        <div class="resort-header-gray p-4 d-flex justify-content-between align-items-center">
            <h2 class="text-white m-0 fw-bold">Create Villa Number</h2>

            <a asp-controller="VillaNumber" asp-action="Index" class="btn btn-outline-light btn-sm">
                Back
            </a>
        </div>

        <!-- Body -->
        <div class="p-4" style="background-color: #2a364a;">

            <form method="post" class="row g-3">

                <!-- Villa Selection -->
                <div class="col-12">
                    <label class="text-white-50">Villa</label>
                    <select asp-for="VillaNumber.VillaId"
                            asp-items="Model.VillaList"
                            class="form-select text-white border-0"
                            style="background-color: #1f2937;">
                        <option disabled selected>-- Select Villa --</option>
                    </select>
                    <span asp-validation-for="VillaNumber.VillaId" class="text-danger"></span>
                </div>

                <!-- Villa Number -->
                <div class="col-md-6">
                    <label class="text-white-50">Villa Number</label>
                    <input asp-for="VillaNumber.Villa_Number"
                           class="form-control text-white border-0"
                           style="background-color: #1f2937;" />
                    <span asp-validation-for="VillaNumber.Villa_Number" class="text-danger"></span>
                </div>

                <!-- Special Details -->
                <div class="col-md-6">
                    <label class="text-white-50">Special Details</label>
                    <input asp-for="VillaNumber.SpecialDetails"
                           class="form-control text-white border-0"
                           style="background-color: #1f2937;" />
                    <span asp-validation-for="VillaNumber.SpecialDetails" class="text-danger"></span>
                </div>

                <!-- Buttons -->
                <div class="d-flex justify-content-end gap-2 pt-3">
                    <a asp-controller="VillaNumber" asp-action="Index"
                       class="btn btn-outline-secondary">
                        Cancel
                    </a>

                    <button type="submit" class="btn btn-gray-steel">
                        <i class="bi bi-check-circle-fill me-2"></i> Create
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>


@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }
}

