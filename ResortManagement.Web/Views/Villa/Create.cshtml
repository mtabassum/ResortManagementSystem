<div class="container mt-5 d-flex justify-content-center">
    <div class="resort-container form-container shadow-lg w-100">

        <!-- Header -->
        <div class="resort-header-gray p-4 d-flex justify-content-between align-items-center">
            <h2 class="text-white m-0 fw-bold">Create Villa</h2>

            <a asp-action="Index" asp-controller="Villa" class="btn btn-outline-light btn-sm">
                Back
            </a>
        </div>

        <!-- Body -->
        <div class="p-4" style="background-color: #2a364a;">

            <form method="post" enctype="multipart/form-data" class="row g-3">

                <!-- Name -->
                <div class="col-12">
                    <label class="text-white-50">Name</label>
                    <input asp-for="Name"
                           class="form-control text-white border-0"
                           style="background-color: #1f2937;" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <!-- Description -->
                <div class="col-12">
                    <label class="text-white-50">Description</label>
                    <textarea asp-for="Description"
                              rows="3"
                              class="form-control text-white border-0"
                              style="background-color: #1f2937;"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <!-- Price -->
                <div class="col-md-6">
                    <label class="text-white-50">Price</label>
                    <input asp-for="Price"
                           class="form-control text-white border-0"
                           style="background-color: #1f2937;" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

                <!-- Sqft -->
                <div class="col-md-6">
                    <label class="text-white-50">Sqft</label>
                    <input asp-for="Sqft"
                           class="form-control text-white border-0"
                           style="background-color: #1f2937;" />
                    <span asp-validation-for="Sqft" class="text-danger"></span>
                </div>

                <!-- Occupancy -->
                <div class="col-12">
                    <label class="text-white-50">Occupancy</label>
                    <input asp-for="Occupancy"
                           class="form-control text-white border-0"
                           style="background-color: #1f2937;" />
                    <span asp-validation-for="Occupancy" class="text-danger"></span>
                </div>

                <!-- Image Upload -->
                <div class="col-12">
                    <label class="text-white-50">Upload Image</label>

                    <input asp-for="ImageUrl" hidden />

                    <input asp-for="Image"
                           type="file"
                           class="form-control text-white border-0"
                           style="background-color: #1f2937;" />

                    <span asp-validation-for="ImageUrl" class="text-danger"></span>
                </div>

                <!-- Buttons -->
                <div class="d-flex justify-content-end gap-2 pt-3">
                    <a asp-controller="Villa" asp-action="Index"
                       class="btn btn-outline-secondary">
                        Cancel
                    </a>

                    <button type="submit" class="btn btn-gray-steel">
                        <i class="bi bi-check-circle-fill me-2"></i> Create
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts{
@{
    <partial name="_ValidationScriptsPartial"/>
}
}