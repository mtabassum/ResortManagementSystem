@model IEnumerable<ResortManagement.Domain.Entities.Villa>

<div class="container mt-5">
    <div class="resort-container shadow-lg">

        <div class="resort-header-gray p-4 d-flex align-items-center">
            <div class="d-flex justify-content-between align-items-center w-100">
                <div>
                    <h2 class="text-white m-0 fw-bold" style="letter-spacing: -0.5px;">Villa List</h2>
                </div>

                <div>
                    <a asp-controller="Villa" asp-action="Create" class="btn btn-gray-steel">
                        <i class="bi bi-plus-square-fill me-2"></i> New Villa
                    </a>
                </div>
            </div>
        </div>

        @* Table Area *@
        <div class="table-responsive">
            <table class="table table-resort table-hover mb-0">
                <thead>
                    <tr>
                        <th style="width: 30%;">Name</th>
                        <th style="width: 15%;">Price</th>
                        <th style="width: 15%;">Sqft</th>
                        <th style="width: 15%;">Occupancy</th>
                        <th class="text-end pe-4" style="width: 25%;">Manage</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var obj in Model)
                    {
                        <tr>
                            <td class="fw-bold">@obj.Name</td>
                            <td>@obj.Price.ToString("C")</td>
                            <td>@obj.Sqft sq ft</td>
                            <td>@obj.Occupancy persons</td>
                            <td class="text-end pe-4">
                                <div class="btn-group gap-2">                            
                                    <a asp-controller="Villa" asp-action="Update" asp-route-villaId="@obj.Id"
                                       class="btn btn-sm btn-outline-secondary border-0 text-white-50">
                                        <i class="bi bi-pencil-fill"></i>
                                    </a>
   
                                    <a asp-controller="Villa" asp-action="Delete" asp-route-villaId="@obj.Id"
                                       class="btn btn-sm btn-outline-danger border-0">
                                        <i class="bi bi-x-circle-fill"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>